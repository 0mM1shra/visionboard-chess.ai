{
  "version": 2,
  "builds": [
    {
      "src": "server/dist/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "client/dist/**",
          "client/public/**",
          "server/dist/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/dist/index.js"
    }
  ]
}
